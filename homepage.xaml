<Page x:Class="emoeat_desk.view.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage"
      Background="#FFF3F6FF">

    <Grid Margin="28">
        <Border MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="White" CornerRadius="18" Padding="24" BorderBrush="#15000000" BorderThickness="1" Height="350" Width="428">
            <StackPanel>
                <TextBlock Text="🍽️ EmoEat " FontSize="28" FontWeight="Bold" Height="53" Width="381"/>
                <TextBlock Text="Choisis ton émotion pour obtenir une recommandation alimentaire" 
                           Margin="0,8,0,20" Foreground="#FF6B7280" TextWrapping="Wrap" Height="17" Width="377"/>

                <Button Content="Joyeux" Click="Emotion_Click" Margin="0,0,0,10" Padding="14,10" FontSize="15" FontWeight="SemiBold" Foreground="White" Background="Green" BorderThickness="0"/>
                <Button Content="Triste" Click="Emotion_Click" Margin="0,0,0,10" Padding="14,10" FontSize="15" FontWeight="SemiBold" Foreground="White" Background="green" BorderThickness="0"/>
                <Button Content="Fatigué" Click="Emotion_Click" Margin="0,0,0,10" Padding="14,10" FontSize="15" FontWeight="SemiBold" Foreground="White" Background="green" BorderThickness="0"/>
                <Button Content="Stressé" Click="Emotion_Click" Margin="0" Padding="14,10" FontSize="15" FontWeight="SemiBold" Foreground="White" Background="Green" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>