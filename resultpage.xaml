<Page x:Class="emoeat_desk.view.ResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ResultPage"
      Background="#FFF3F6FF">

    <Grid Margin="28">
        <Border MaxWidth="620" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="White" CornerRadius="18" Padding="24" BorderBrush="#15000000" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Button Content="← Retour" Click="Back_Click" Width="130" Padding="12,8" FontSize="14" FontWeight="SemiBold" Foreground="White" Background="#FF0EA5E9" BorderThickness="0"/>

                    <Border x:Name="EmotionHeader" Margin="0,14,0,12" CornerRadius="14" Background="#FFDCFCE7" Padding="14">
                        <DockPanel>
                            <TextBlock x:Name="EmotionIconText" Text="😊" FontSize="34" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="MoodMessageText" Foreground="#FF374151" FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <TextBlock Text="🍴 Recommandations" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="FoodList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="12" CornerRadius="10" Background="#FFF8FAFC" BorderBrush="#22000000" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Reason}" Margin="0,4,0,0" Foreground="#FF6B7280" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="💡 Conseils" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,6"/>
                    <Border Background="#FFF9FAFB" CornerRadius="10" Padding="12" BorderBrush="#22000000" BorderThickness="1">
                        <TextBlock x:Name="TipsText" TextWrapping="Wrap" Foreground="#FF374151"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>