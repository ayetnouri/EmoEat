<Application x:Class="emoeat_desk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:emoeat_desk"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF7FAFF" Offset="0"/>
            <GradientStop Color="#FFEFF4FF" Offset="1"/>
        </LinearGradientBrush>
    </Application.Resources>
</Application>
